PORT=3000
NODE_ENV=development
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=replace_with_a_long_random_secret
ENCRYPTION_KEY=64_hex_characters_for_aes_256_gcm

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Public deployed app URL. On Vercel this can be omitted if VERCEL_URL is available,
# but setting APP_URL to your production domain is recommended.
APP_URL=https://your-vercel-domain.vercel.app

# Gmail SMTP. Use a Gmail App Password, not your normal account password.
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
MAIL_FROM=VaultX <your-gmail-address@gmail.com>

# Optional generic SMTP equivalents.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-gmail-address@gmail.com
# SMTP_PASS=your_gmail_app_password
